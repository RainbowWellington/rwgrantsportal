{
  "buildCommand": "vite build",
  "outputDirectory": ".vercel/output",
  "framework": null,
  "headers": [
    {
      "source": "/apply",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    }
  ]
}
